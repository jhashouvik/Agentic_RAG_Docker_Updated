    <!-- AgentState box -->
    <mxCell id="agent_state" value="&lt;b&gt;AgentState (TypedDict)&lt;/b&gt;&#xa;question: str&#xa;vectorstore: FAISS&#xa;retrieved_docs: list&#xa;graded_docs: list&#xa;answer: str&#xa;chat_history: str&#xa;tokens_used: int" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;" vertex="1" parent="1">
