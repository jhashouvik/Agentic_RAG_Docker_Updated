    </mxCell>

    <!-- Summary generation -->
    <mxCell id="summary_gen" value="&lt;b&gt;Auto Summary&lt;/b&gt;&#xa;Orchestrator&#xa;──────────────&#xa;full_text[:12000]&#xa;→ GPT-4o (temp=0.2)&#xa;→ Markdown summary&#xa;  (Overview, Topics,&#xa;   Findings, Data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=10;align=left;" vertex="1" parent="1">
