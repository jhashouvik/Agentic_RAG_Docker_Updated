    </mxCell>

    <!-- Node 1: RETRIEVE -->
    <mxCell id="node_retrieve" value="&lt;b&gt;Node 1: RETRIEVE&lt;/b&gt;&#xa;agent_orchestrator.py&#xa;─────────────────────&#xa;1. Embed question&#xa;   (same model as chunks)&#xa;2. FAISS cosine similarity&#xa;3. Return top-K chunks&#xa;   with scores (0–1)&#xa;─────────────────────&#xa;Output: retrieved_docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="470" y="450" width="200" height="165" as="geometry" />
    </mxCell>

    <!-- Node 2: GRADE -->
    <mxCell id="node_grade" value="&lt;b&gt;Node 2: GRADE&lt;/b&gt;&#xa;agent_orchestrator.py&#xa;─────────────────────&#xa;For each chunk → GPT-4o-mini:&#xa;  &quot;RELEVANT or IRRELEVANT?&quot;&#xa;Filter irrelevant chunks&#xa;Fallback: use all if 100%&#xa;filtered (avoids empty ans)&#xa;─────────────────────&#xa;Output: graded_docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="730" y="450" width="210" height="165" as="geometry" />
    </mxCell>

    <!-- Node 3: GENERATE -->
    <mxCell id="node_generate" value="&lt;b&gt;Node 3: GENERATE&lt;/b&gt;&#xa;agent_orchestrator.py&#xa;──────────────────────&#xa;1. Format context block:&#xa;   [Page|Chunk|Score]&#xa;   {chunk text} ---&#xa;2. Inject last-5 turns&#xa;   from AgentMemory window&#xa;3. Call GPT-4o (temp=0.2)&#xa;   with RAG_PROMPT&#xa;──────────────────────&#xa;Output: answer, tokens_used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="1000" y="445" width="210" height="175" as="geometry" />
    </mxCell>

